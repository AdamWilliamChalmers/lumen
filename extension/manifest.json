{
  "manifest_version": 3,
  "name": "Lumen",
  "version": "3.0.0",
  "description": "Stay conscious of how you think alongside AI.",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://x.com/*",
    "http://localhost:3000/*",
    "https://api.lumen.so/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://x.com/i/grok*"
      ],
      "js": [
        "goals.js",
        "nudges.js",
        "engine.js",
        "adapters/chatgpt.js",
        "adapters/claude.js",
        "adapters/gemini.js",
        "adapters/grok.js",
        "session.js",
        "content.js"
      ],
      "css": ["widget.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  }
}
